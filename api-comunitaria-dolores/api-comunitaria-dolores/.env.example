# Copia este archivo como .env y ajusta los valores

# Ambiente: dev, prod, test
FLASK_CONFIG=dev

# Puerto del servidor
PORT=5000

# Secret key para sesiones (¡CAMBIAR EN PRODUCCIÓN!)
SECRET_KEY=dev-secret-key-change-in-production

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/api.log

# Base de datos (para Bloque 2 con PostgreSQL)
DATABASE_URL=postgresql://admin:desarrollo123@localhost:5432/api_comunitaria
